datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ModelStatus {
  UPLOADING
  PROCESSING
  READY
  ERROR
}

enum JobType {
  OPTIMIZE
  CONVERT
  GENERATE_THUMBNAIL
}

enum JobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

model User {
  id           String    @id @default(uuid()) @map("id")
  email        String    @unique @map("email")
  passwordHash String    @map("password_hash")
  name         String    @map("name")
  role         Role      @default(VIEWER) @map("role")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  projects Project[]
  models   Model3D[]

  @@map("users")
}

model Project {
  id          String        @id @default(uuid()) @map("id")
  name        String        @map("name")
  description String?       @map("description")
  userId      String        @map("user_id")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      ProjectStatus @default(DRAFT) @map("status")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  models Model3D[]

  @@map("projects")
}

model Model3D {
  id           String      @id @default(uuid()) @map("id")
  name         String      @map("name")
  fileName     String      @map("file_name")
  fileSize     Int         @map("file_size")
  format       String      @map("format")
  storageKey      String      @map("storage_key")
  thumbnailKey    String?     @map("thumbnail_key")
  refStorageKeys  Json?       @map("ref_storage_keys")
  status          ModelStatus @default(UPLOADING) @map("status")
  projectId    String      @map("project_id")
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId       String      @map("user_id")
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  jobs Job[]

  @@map("model3d")
}

model Job {
  id           String    @id @default(uuid()) @map("id")
  type         JobType   @map("type")
  status       JobStatus @default(PENDING) @map("status")
  modelId      String    @map("model_id")
  model        Model3D   @relation(fields: [modelId], references: [id], onDelete: Cascade)
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("jobs")
}
