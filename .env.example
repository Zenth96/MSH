# PostgreSQL
POSTGRES_PASSWORD=msh_secret

# RabbitMQ
RABBITMQ_USER=msh
RABBITMQ_PASSWORD=msh_secret
RABBITMQ_URL=amqp://msh:msh_secret@localhost:5672

# MinIO
MINIO_ROOT_USER=msh
MINIO_ROOT_PASSWORD=msh_secret
# Docker-en belül a backend "minio"-n éri el, a presigned URL-ek "localhost"-on
MINIO_PUBLIC_ENDPOINT=localhost
MINIO_PUBLIC_PORT=9000

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# Backend URL (frontend használja)
API_URL=http://localhost:3000
